---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — Argentina Investment Visa`}
  description={post.data.description}
>
  <Navbar />
  <main class="pt-16 min-h-screen">
    <article class="py-16 md:py-24">
      <div class="max-w-2xl mx-auto px-6">
        <a href="/insights" class="text-[#525252] text-sm hover:text-[#1a1a1a] mb-6 inline-block">
          ← Insights
        </a>
        <time class="text-[#737373] text-sm block" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="font-[family-name:var(--font-heading)] text-3xl md:text-4xl text-[#1a1a1a] font-semibold mt-2 mb-6">
          {post.data.title}
        </h1>
        <div class="prose prose-neutral max-w-none text-[#525252] [&_a]:text-[#1a1a1a] [&_a]:underline [&_h2]:font-[family-name:var(--font-heading)] [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:mt-8 [&_h2]:mb-3 [&_p]:leading-relaxed [&_p]:mb-4">
          <Content />
        </div>
      </div>
    </article>
    <Footer />
  </main>
</Layout>
