---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Argentina Investment Visa — Citizenship by Investment Program"
  description="Argentina has officially launched its Citizenship by Investment program. Learn about the program and register your interest for priority access."
>
  <Navbar />
  <main>
    <Hero />
    <TrustBar />
    <section class="py-16 md:py-20 bg-[#fafaf9] border-t border-[#e5e5e4]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-[family-name:var(--font-heading)] text-2xl md:text-3xl text-[#1a1a1a] font-semibold mb-6 reveal" data-reveal>
          Explore
        </h2>
        <p class="text-[#525252] mb-10 reveal" data-reveal>
          Learn about the program, key benefits, and how to register your interest.
        </p>
        <div class="flex flex-wrap justify-center gap-4 reveal" data-reveal>
          <a href="/about" class="text-[#1a1a1a] font-medium underline underline-offset-4 hover:no-underline">About</a>
          <a href="/program" class="text-[#1a1a1a] font-medium underline underline-offset-4 hover:no-underline">Program</a>
          <a href="/insights" class="text-[#1a1a1a] font-medium underline underline-offset-4 hover:no-underline">Insights</a>
          <a href="/faq" class="text-[#1a1a1a] font-medium underline underline-offset-4 hover:no-underline">FAQ</a>
          <a href="/contact" class="bg-[#1a1a1a] text-white px-6 py-3 text-sm font-medium hover:bg-[#333] transition-colors">Request early access</a>
        </div>
      </div>
    </section>
    <Footer />
  </main>
</Layout>
