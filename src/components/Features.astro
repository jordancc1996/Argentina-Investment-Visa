---
const features = [
  {
    icon: "passport",
    title: "Official legal framework",
    description:
      "Enacted via Presidential Decree 524/2025, the program carries full legal authority and government backing.",
  },
  {
    icon: "shield",
    title: "Rigorous security vetting",
    description:
      "Seven government agencies conduct thorough due diligence, ensuring the program meets international standards.",
  },
  {
    icon: "clock",
    title: "Fast-track decisions",
    description:
      "The National Directorate of Migration is mandated to issue final citizenship decisions within 30 business days.",
  },
  {
    icon: "airplane",
    title: "US Visa Waiver upside",
    description:
      "Argentina's July 2025 application to rejoin the US Visa Waiver Program could grant passport holders visa-free US access.",
  },
  {
    icon: "chart",
    title: "Early mover advantage",
    description:
      "Investment thresholds and approved sectors are pending — those who engage now will be best positioned at launch.",
  },
  {
    icon: "building",
    title: "South America's premier economy",
    description:
      "Argentina offers a sophisticated economy, rich culture, European heritage, and a world-class quality of life.",
  },
];
---

<section id="program" class="py-16 md:py-24 bg-white" aria-labelledby="features-heading">
  <div class="max-w-6xl mx-auto px-6">
    <p class="eyebrow text-center mb-3 reveal" data-reveal>Why Argentina</p>
    <h2
      id="features-heading"
      class="font-[family-name:var(--font-heading)] text-3xl md:text-4xl text-[#1a1a1a] font-semibold text-center mb-12 reveal"
      data-reveal
    >
      A rare opportunity at the right moment
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {features.map((feature, i) => (
        <div
          class="reveal bg-[#fafaf9] border border-[#e5e5e4] p-6 md:p-8 hover:border-[#d4d4d4] transition-colors"
          data-reveal
        >
          <div class="text-[#1a1a1a] mb-4" aria-hidden="true">
            {feature.icon === "passport" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0h.5a2.5 2.5 0 002.5-2.5V3.935M12 12a3 3 0 100 6 3 3 0 000-6z" />
              </svg>
            )}
            {feature.icon === "shield" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
            {feature.icon === "clock" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {feature.icon === "airplane" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
              </svg>
            )}
            {feature.icon === "chart" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            )}
            {feature.icon === "building" && (
              <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            )}
          </div>
          <h3 class="text-[#1a1a1a] font-[family-name:var(--font-heading)] text-xl font-semibold mb-2">
            {feature.title}
          </h3>
          <p class="text-[#525252] text-[0.9375rem] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
