---
const formAction = "https://formcarry.com/s/GcoYSniuvie";
---

<section id="contact" class="py-16 md:py-24 bg-[#f5f5f4] border-t border-[#e5e5e4]" aria-labelledby="lead-heading">
  <div class="max-w-md mx-auto px-6">
    <div id="lead-form-card" class="bg-white border border-[#e5e5e4] p-8 md:p-10">
      <p class="eyebrow mb-3 reveal" data-reveal>Secure your position</p>
      <h2
        id="lead-heading"
        class="font-[family-name:var(--font-heading)] text-2xl md:text-3xl text-[#1a1a1a] font-semibold mb-4 reveal"
        data-reveal
      >
        Be first when Argentina opens its doors
      </h2>
      <p class="text-[#525252] text-sm md:text-base mb-8 reveal" data-reveal>
        Investment thresholds are still being defined. Register your interest today and receive exclusive updates, priority access, and expert guidance when the program launches.
      </p>

      <div id="form-wrapper">
        <form
          id="lead-form"
          action={formAction}
          method="POST"
          class="space-y-5 reveal"
          data-reveal
        >
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
          <div>
            <label for="name" class="block text-[#525252] text-xs font-medium mb-1.5">Full name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-white border border-[#e5e5e4] text-[#1a1a1a] px-4 py-3 text-sm focus:outline-none focus:border-[#1a1a1a] transition-colors"
              placeholder="Your full name"
            />
          </div>
          <div>
            <label for="email" class="block text-[#525252] text-xs font-medium mb-1.5">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-white border border-[#e5e5e4] text-[#1a1a1a] px-4 py-3 text-sm focus:outline-none focus:border-[#1a1a1a] transition-colors"
              placeholder="your@email.com"
            />
          </div>
          <div>
            <label for="country" class="block text-[#525252] text-xs font-medium mb-1.5">Country of residence (optional)</label>
            <input
              type="text"
              id="country"
              name="country"
              class="w-full bg-white border border-[#e5e5e4] text-[#1a1a1a] px-4 py-3 text-sm focus:outline-none focus:border-[#1a1a1a] transition-colors"
              placeholder="e.g. United States"
            />
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-[#1a1a1a] text-white font-medium py-3.5 px-6 text-sm hover:bg-[#333] transition-colors disabled:opacity-60"
          >
            Request early access →
          </button>
          <p class="text-[#737373] text-xs text-center">
            Your information is kept strictly confidential. We do not sell or share your data.
          </p>
        </form>
      </div>

      <div id="success-message" class="hidden text-center py-8">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-full border-2 border-[#1a1a1a] text-[#1a1a1a] mb-4" aria-hidden="true">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <p class="font-[family-name:var(--font-heading)] text-xl text-[#1a1a1a]">Thank you. We'll be in touch shortly.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form');
  const formWrapper = document.getElementById('form-wrapper');
  const successMessage = document.getElementById('success-message');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !formWrapper || !successMessage) return;
    submitBtn.setAttribute('disabled', '');
    submitBtn.textContent = 'Sending…';
    const formData = new FormData(form as HTMLFormElement);
    try {
      const res = await fetch((form as HTMLFormElement).action, {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        formWrapper.classList.add('hidden');
        successMessage.classList.remove('hidden');
      } else {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = 'Request early access →';
      }
    } catch {
      submitBtn.removeAttribute('disabled');
      submitBtn.textContent = 'Request early access →';
    }
  });
</script>
