---
const heroImage = "https://images.unsplash.com/photo-1589909202802-8f4aadce1849?w=1920&q=80";
---

<section class="relative pt-24 md:pt-32 pb-16 md:pb-24 bg-[#f5f5f4]" aria-label="Introduction">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <p class="eyebrow mb-4 reveal" data-reveal>
      Argentina Citizenship by Investment
    </p>
    <h1 class="font-[family-name:var(--font-heading)] text-4xl md:text-5xl lg:text-[3.25rem] font-semibold text-[#1a1a1a] leading-tight mb-6 reveal" data-reveal>
      Your path to Argentine citizenship starts here
    </h1>
    <p class="text-[#525252] text-lg md:text-xl max-w-2xl mx-auto mb-10 reveal" data-reveal>
      Argentina has officially launched its Citizenship by Investment program. Be among the first to secure your position.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center reveal" data-reveal>
      <a
        href="#contact"
        class="inline-flex justify-center bg-[#1a1a1a] text-white font-medium px-8 py-3.5 text-sm hover:bg-[#333] transition-colors"
      >
        Request Early Access
      </a>
      <a
        href="#about"
        class="inline-flex justify-center border border-[#1a1a1a] text-[#1a1a1a] px-8 py-3.5 text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors"
      >
        Learn more
      </a>
    </div>
  </div>
</section>
