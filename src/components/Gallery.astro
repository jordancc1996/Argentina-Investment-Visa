---
const images = [
  { src: "https://images.unsplash.com/photo-1588714477688-cf28a50e94f7?w=800&q=80", alt: "Buenos Aires cityscape" },
  { src: "https://images.unsplash.com/photo-1546074177-ffdda98d214f?w=800&q=80", alt: "Patagonia landscape" },
  { src: "https://images.unsplash.com/photo-1612294037637-ec328d0e075e?w=800&q=80", alt: "Argentina architecture" },
  { src: "https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=800&q=80", alt: "Lifestyle in Argentina" },
  { src: "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=80", alt: "Elegant interior" },
];
---

<section class="py-16 md:py-24 bg-[#f5f5f4]" aria-labelledby="gallery-heading">
  <div class="max-w-6xl mx-auto px-6">
    <p class="eyebrow text-center mb-3 reveal" data-reveal>Argentina</p>
    <h2
      id="gallery-heading"
      class="font-[family-name:var(--font-heading)] text-3xl md:text-4xl text-[#1a1a1a] font-semibold text-center mb-12 reveal"
      data-reveal
    >
      A country worth calling home
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {images.map((img, i) => (
        <div class="reveal overflow-hidden" data-reveal>
          <img
            src={img.src}
            alt={img.alt}
            class="w-full aspect-[4/3] md:aspect-[3/4] object-cover hover:opacity-95 transition-opacity duration-300"
            width="800"
            height="600"
          />
        </div>
      ))}
    </div>
  </div>
</section>
