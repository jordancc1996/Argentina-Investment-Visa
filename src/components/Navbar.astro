---
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5 px-6 md:px-12"
  aria-label="Main navigation"
>
  <nav class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="text-[#C9A84C] font-medium text-sm tracking-[0.15em] uppercase">
      Argentina Investment Visa
    </a>

    <ul class="hidden md:flex items-center gap-10 text-[#A89F8C] text-sm tracking-wider">
      <li><a href="#about" class="hover:text-[#F5EDD6] transition-colors">About</a></li>
      <li><a href="#program" class="hover:text-[#F5EDD6] transition-colors">Program</a></li>
      <li><a href="#faq" class="hover:text-[#F5EDD6] transition-colors">FAQ</a></li>
      <li><a href="#contact" class="hover:text-[#F5EDD6] transition-colors">Contact</a></li>
      <li>
        <a
          href="#contact"
          class="border border-[#C9A84C] text-[#C9A84C] px-5 py-2.5 hover:bg-[#C9A84C] hover:text-[#0A0A0A] transition-all duration-300"
        >
          Get Early Access
        </a>
      </li>
    </ul>

    <button
      id="menu-toggle"
      type="button"
      class="md:hidden text-[#F5EDD6] p-2"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-[#0A0A0A]/98 hidden md:hidden flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <a href="#about" class="text-[#F5EDD6] text-lg tracking-wider hover:text-[#C9A84C] nav-mobile-link">About</a>
  <a href="#program" class="text-[#F5EDD6] text-lg tracking-wider hover:text-[#C9A84C] nav-mobile-link">Program</a>
  <a href="#faq" class="text-[#F5EDD6] text-lg tracking-wider hover:text-[#C9A84C] nav-mobile-link">FAQ</a>
  <a href="#contact" class="text-[#F5EDD6] text-lg tracking-wider hover:text-[#C9A84C] nav-mobile-link">Contact</a>
  <a
    href="#contact"
    class="border border-[#C9A84C] text-[#C9A84C] px-6 py-3 hover:bg-[#C9A84C] hover:text-[#0A0A0A] transition-all"
  >
    Get Early Access
  </a>
</div>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  function updateNavbarBackground() {
    if (window.scrollY > 40) {
      navbar?.classList.add('bg-[#0A0A0A]/95', 'backdrop-blur-sm');
    } else {
      navbar?.classList.remove('bg-[#0A0A0A]/95', 'backdrop-blur-sm');
    }
  }

  window.addEventListener('scroll', updateNavbarBackground, { passive: true });
  updateNavbarBackground();

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('!flex');
    mobileMenu?.classList.toggle('opacity-100');
    mobileMenu?.classList.toggle('pointer-events-auto');
    menuToggle?.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  mobileMenu?.querySelectorAll('.nav-mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('!flex', 'opacity-100', 'pointer-events-auto');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
