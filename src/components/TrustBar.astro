---
const stats = [
  { value: "Decree 524/2025", label: "Officially Enacted" },
  { value: "30 Days", label: "Decision Timeline" },
  { value: "7 Agencies", label: "Security Vetted" },
  { value: "US Visa Waiver", label: "Application Submitted" },
];
---

<section class="bg-[#111111] py-12 md:py-16 border-y border-[rgba(201,168,76,0.2)]" aria-label="Trust indicators">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-[rgba(201,168,76,0.2)]">
      {stats.map((stat, i) => (
        <div
          class="reveal text-center px-4 md:px-8 first:pl-0 last:pr-0"
          data-reveal
          style={i > 0 ? `transition-delay: ${i * 0.1}s` : undefined}
        >
          <p class="text-[#C9A84C] font-[family-name:var(--font-heading)] text-xl md:text-2xl font-semibold">
            {stat.value}
          </p>
          <p class="text-[#A89F8C] text-sm mt-1 tracking-wider">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
