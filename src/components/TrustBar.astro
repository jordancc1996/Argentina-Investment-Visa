---
const stats = [
  { value: "Decree 524/2025", label: "Officially enacted" },
  { value: "30 days", label: "Decision timeline" },
  { value: "7 agencies", label: "Security vetted" },
  { value: "US Visa Waiver", label: "Application submitted" },
];
---

<section class="bg-white border-y border-[#e5e5e4] py-10 md:py-12" aria-label="Program at a glance">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x divide-[#e5e5e4]">
      {stats.map((stat, i) => (
        <div class="reveal text-center px-4 md:px-6" data-reveal>
          <p class="text-[#1a1a1a] font-[family-name:var(--font-heading)] text-xl md:text-2xl font-semibold">
            {stat.value}
          </p>
          <p class="text-[#525252] text-sm mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
